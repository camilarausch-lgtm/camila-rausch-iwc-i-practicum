doctype html
html
  head
    title= title
    meta(name="viewport" content="width=device-width, initial-scale=1")
    link(rel="stylesheet", href="/css/style.css")
  body
    h1 Pets
    a(href="/update-cobj") Add to this table
    table
      thead
        tr
          th Name
          th Species
          th Bio
      tbody
        each item in data
          tr
            td #{item.properties.name}
            td #{item.properties.species}
            td #{item.properties.bio}
